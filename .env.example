JARVIS_PROVIDER=ollama
JARVIS_FALLBACK=openai,ollama
JARVIS_MODEL=qwen3:8b
JARVIS_OLLAMA_BASE=http://127.0.0.1:11434

# LLM API Keys: nur lokal in .env setzen, echte Keys nicht committen.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

JARVIS_GITHUB_OWNER=your-github-owner
JARVIS_GITHUB_REPO=your-private-repo
JARVIS_GITHUB_RELEASE=latest
JARVIS_GITHUB_PACKAGE_ASSET=JARVIS_B6_5_PRODUCTION_INSTALLER_HOTFIX.zip
JARVIS_GITHUB_MANIFEST_ASSET=jarvis-update-manifest.json

# Create a fine-grained GitHub token with read-only access to the private repo contents/releases.
# Do not commit real tokens.
JARVIS_GITHUB_TOKEN=replace_with_local_token
